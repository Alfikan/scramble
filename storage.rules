rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // User profile images - users can only upload their own profile images
    match /users/{userId}/profile/{allPaths=**} {
      allow read: if true; // Profile images can be read by anyone
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024 // 5MB limit
        && request.resource.contentType.matches('image/.*'); // Only images
    }
    
    // Room files - only room members can upload/download
    match /rooms/{roomId}/files/{allPaths=**} {
      allow read, write: if request.auth != null; // Simplified for now
      // TODO: Add room membership check when implementing file sharing
    }
    
    // Study materials - authenticated users can read, only creators can write
    match /materials/{materialId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024; // 50MB limit for study materials
    }
    
    // Default deny all other files
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}